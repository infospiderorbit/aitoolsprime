fs = require("fs");
const puppeteer = require("puppeteer");

const URL = "https://www.toolify.ai/category/ai-girlfriend";

(async () => {
  const browser = await puppeteer.launch({ headless: true });
  const page = await browser.newPage();

  await page.goto(URL, { waitUntil: "networkidle2" });

  let prevHeight;
  while (true) {
    prevHeight = await page.evaluate(() => document.body.scrollHeight);
    await page.evaluate(() => window.scrollTo(0, 
document.body.scrollHeight));
    await new Promise(r => setTimeout(r, 2000));

    const newHeight = await page.evaluate(() => 
document.body.scrollHeight);
    if (newHeight === prevHeight) break;
  }

  await page.waitForSelector("a");

  const tools = await page.evaluate(() => {
    const data = [];
    const links = document.querySelectorAll("a");

    links.forEach(el => {
      const href = el.getAttribute("href");
      const name = el.innerText.trim();

      if (href && href.includes("/tool/") && name.length > 2) {
        data.push({
          name,
          url: "https://www.toolify.ai" + href
        });
      }
    });

    return data;
  });

  const unique = Array.from(new Map(tools.map(t => [t.url, t])).values());

  fs.writeFileSync("toolify-ai-girlfriend.json", JSON.stringify(unique, 
null, 2));

  console.log("Scraped tools:", unique.length);

  await browser.close();
})();
